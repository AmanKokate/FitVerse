# Email Configuration
EMAIL_HOST_USER=team.fitverse@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Instructions to get Gmail App Password:
# 1. Go to your Google Account (myaccount.google.com)
# 2. Select Security
# 3. Under "How you sign in to Google," select 2-Step Verification
# 4. At the bottom, select App passwords
# 5. Select "Mail" and your device, then Generate
# 6. Copy the 16-character password and paste it here
